{
  "id": "kaizen-route",
  "title": "Kaizen // Rival Link",
  "startSceneId": "opening",
  "scenes": {
    "opening": {
      "id": "opening",
      "title": "Rival Challenge",
      "steps": [
        {
          "type": "visual",
          "background": "/sunset_terminal_bg.png",
          "portrait": "/portrait_kaizen.svg",
          "bustLeft": "/avatar_player.png",
          "bustRight": "/portrait_kaizen.svg",
          "focusSide": "right",
          "transition": "fade"
        },
        {
          "type": "audio",
          "action": "play-bgm",
          "track": "bgm_rival_link"
        },
        {
          "type": "dialogue",
          "speakerId": "kaizen",
          "text": "You made it. Good. Sunset Terminal feels too small when we are both standing still.",
          "portrait": "/portrait_kaizen.svg",
          "bustLeft": "/avatar_player.png",
          "bustRight": "/portrait_kaizen.svg",
          "focusSide": "right"
        },
        {
          "type": "choice",
          "id": "kaizen_choice",
          "prompt": "How do you answer your rival?",
          "options": [
            {
              "id": "sync",
              "text": "Tell her you still remember her rhythm from the last duel.",
              "conditions": [
                {
                  "relationship": "kaizen",
                  "min": 2
                }
              ],
              "effects": {
                "relationships": {
                  "kaizen": 1
                },
                "flags": {
                  "launchBattle": true
                },
                "variables": {
                  "playerMood": "locked_in"
                }
              }
            },
            {
              "id": "accept",
              "text": "Accept the challenge.",
              "effects": {
                "relationships": {
                  "kaizen": 2
                },
                "flags": {
                  "launchBattle": true
                }
              }
            },
            {
              "id": "wait",
              "text": "Tell her you need a moment.",
              "effects": {
                "relationships": {
                  "kaizen": 1
                },
                "variables": {
                  "playerMood": "steady"
                }
              }
            }
          ]
        },
        {
          "type": "dialogue",
          "speakerId": "kaizen",
          "text": "So you were paying attention. Good. I hate wasting my best games on strangers.",
          "conditions": [
            {
              "choice": "kaizen_choice",
              "choiceEquals": "sync"
            }
          ],
          "portrait": "/portrait_kaizen.svg",
          "bustLeft": "/avatar_player.png",
          "bustRight": "/portrait_kaizen.svg",
          "focusSide": "right"
        },
        {
          "type": "dialogue",
          "speakerId": "kaizen",
          "text": "Then stop hesitating. The city is already watching.",
          "conditions": [
            {
              "choice": "kaizen_choice",
              "choiceEquals": "accept"
            }
          ],
          "portrait": "/portrait_kaizen.svg",
          "bustLeft": "/avatar_player.png",
          "bustRight": "/portrait_kaizen.svg",
          "focusSide": "right"
        },
        {
          "type": "dialogue",
          "speakerId": "kaizen",
          "text": "Take the breath you need. Just don't confuse calm with cowardice.",
          "conditions": [
            {
              "choice": "kaizen_choice",
              "choiceEquals": "wait"
            }
          ],
          "portrait": "/portrait_kaizen.svg",
          "bustLeft": "/avatar_player.png",
          "bustRight": "/portrait_kaizen.svg",
          "focusSide": "right"
        }
      ]
    }
  }
}
