{
  "id": "vex-route",
  "title": "Vex // Pulse Clash",
  "startSceneId": "opening",
  "scenes": {
    "opening": {
      "id": "opening",
      "title": "Velocity Clash",
      "steps": [
        {
          "type": "visual",
          "background": "/market_arcade_bg.png",
          "portrait": "/portrait_vex.svg",
          "bustLeft": "/avatar_player.png",
          "bustRight": "/bust_vex.svg",
          "focusSide": "right",
          "transition": "fade"
        },
        {
          "type": "dialogue",
          "speakerId": "vex",
          "text": "You can tell everything about a duelist from their first two moves. So make yours fast.",
          "portrait": "/portrait_vex.svg",
          "bustLeft": "/avatar_player.png",
          "bustRight": "/bust_vex.svg",
          "focusSide": "right"
        },
        {
          "type": "choice",
          "id": "vex_choice",
          "prompt": "How do you answer the Pulse master?",
          "options": [
            {
              "id": "match_his_speed",
              "text": "Tell her you came to outrun her, not just keep up.",
              "conditions": [
                {
                  "relationship": "vex",
                  "min": 2
                }
              ],
              "effects": {
                "relationships": {
                  "vex": 1
                },
                "flags": {
                  "launchBattle": true
                },
                "variables": {
                  "playerMood": "electric"
                }
              }
            },
            {
              "id": "race",
              "text": "Challenge her immediately.",
              "effects": {
                "relationships": {
                  "vex": 2
                },
                "flags": {
                  "launchBattle": true
                }
              }
            },
            {
              "id": "study",
              "text": "Study the arena first.",
              "effects": {
                "relationships": {
                  "vex": 1
                },
                "variables": {
                  "playerMood": "focused"
                }
              }
            }
          ]
        },
        {
          "type": "dialogue",
          "speakerId": "vex",
          "text": "Finally. Somebody in this city understands that confidence is also a tempo play.",
          "conditions": [
            {
              "choice": "vex_choice",
              "choiceEquals": "match_his_speed"
            }
          ],
          "portrait": "/portrait_vex.svg",
          "bustLeft": "/avatar_player.png",
          "bustRight": "/bust_vex.svg",
          "focusSide": "right"
        },
        {
          "type": "dialogue",
          "speakerId": "vex",
          "text": "Either way, keep up. I don't slow down for anyone.",
          "conditions": [
            {
              "choice": "vex_choice",
              "choiceEquals": "race"
            }
          ],
          "portrait": "/portrait_vex.svg",
          "bustLeft": "/avatar_player.png",
          "bustRight": "/bust_vex.svg",
          "focusSide": "right"
        },
        {
          "type": "dialogue",
          "speakerId": "vex",
          "text": "Planning is fine. Just don't think so long that the duel finishes without you.",
          "conditions": [
            {
              "choice": "vex_choice",
              "choiceEquals": "study"
            }
          ],
          "portrait": "/portrait_vex.svg",
          "bustLeft": "/avatar_player.png",
          "bustRight": "/bust_vex.svg",
          "focusSide": "right"
        }
      ]
    }
  }
}
